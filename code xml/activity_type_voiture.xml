<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TypeVoiture"
    android:background="#C1F0F0"
    >

    <ImageView
        android:id="@+id/logo"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:src="@drawable/voiturechoix" />
    <ImageButton
        android:layout_below="@+id/logo"
        android:id="@+id/btnMercedes"
        android:layout_width="200dp"
        android:layout_marginTop="20dp"
        android:layout_height="200dp"
        android:layout_alignParentStart="true"
    android:layout_margin="10dp"
    android:layout_marginEnd="20dp"
    android:contentDescription="Mercedes"
    android:scaleType="fitCenter"
    android:src="@drawable/ic_mercedes" />

    <ImageButton
        android:layout_below="@+id/logo"
        android:id="@+id/btnRenaut"
        android:layout_marginTop="20dp"
        android:layout_toEndOf="@id/btnMercedes"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_alignParentEnd="true"
    android:layout_margin="10dp"
    android:contentDescription="Renault"
    android:scaleType="fitCenter"
    android:src="@drawable/ic_renault" />

    <ImageButton
        android:id="@+id/btnPeugeot"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_alignParentStart="true"
        android:layout_margin="10dp"
        android:layout_marginEnd="20dp"
        android:contentDescription="Peugeot"
        android:layout_below="@+id/btnRenaut"
        android:scaleType="fitCenter"
        android:src="@drawable/peugeot" />
    <ImageButton
        android:id="@+id/btnopel"
        android:layout_toEndOf="@id/btnPeugeot"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_alignParentEnd="true"
        android:layout_margin="10dp"
        android:contentDescription="opel"
        android:scaleType="fitCenter"
        android:src="@drawable/opel"
        android:layout_below="@+id/btnRenaut"
        />
    <ImageButton
        android:id="@+id/btnvolkswagen"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_alignParentStart="true"
        android:layout_margin="10dp"
        android:layout_marginEnd="20dp"
        android:contentDescription="volkswagen"
        android:layout_below="@+id/btnopel"
        android:scaleType="fitCenter"
        android:src="@drawable/volkswagen1" />
    <ImageButton
        android:id="@+id/Dacialogo"
        android:layout_toEndOf="@id/btnvolkswagen"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_alignParentEnd="true"
        android:layout_margin="10dp"
        android:contentDescription="Dacia"
        android:scaleType="fitCenter"
        android:src="@drawable/dacialogo"
        android:layout_below="@+id/btnopel"
        />
</RelativeLayout>
